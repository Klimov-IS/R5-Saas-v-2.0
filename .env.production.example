# Production Environment Configuration
# Copy this file to .env.local on the server and fill in values

# ============================================================================
# Node Environment
# ============================================================================
NODE_ENV=production
PORT=3000

# ============================================================================
# PostgreSQL Database (Yandex Managed PostgreSQL)
# IMPORTANT: var name is POSTGRES_DB (not POSTGRES_DATABASE!)
# ============================================================================
POSTGRES_HOST=rc1a-u6gmh29sivrjjbc8.mdb.yandexcloud.net
POSTGRES_PORT=6432
POSTGRES_DB=wb_reputation
POSTGRES_USER=admin_R5
POSTGRES_PASSWORD=YOUR_PASSWORD_HERE
POSTGRES_SSL=require

# ============================================================================
# API & Auth
# ============================================================================
NEXT_PUBLIC_API_URL=https://rating5.ru
NEXT_PUBLIC_API_KEY=YOUR_API_KEY_HERE
NEXT_PUBLIC_BASE_URL=http://localhost:3000
JWT_SECRET=YOUR_JWT_SECRET_HERE

# ============================================================================
# Deepseek AI
# ============================================================================
# DEEPSEEK_API_KEY=your-deepseek-key-here

# ============================================================================
# Telegram Mini App
# ============================================================================
# TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
